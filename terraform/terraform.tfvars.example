# Copy this file to terraform.tfvars and fill in your values.
#
#   cp terraform.tfvars.example terraform.tfvars
#
# terraform.tfvars is gitignored so your personal values stay local.

# Required: set a unique prefix for your bucket names.
# Must be lowercase letters, numbers, and hyphens only.
# Example: "johndoe" creates "johndoe-dr-primary" and "johndoe-dr-secondary"
bucket_prefix = "yourname"

# Optional: change regions if you prefer different ones.
primary_region   = "us-east-1"
secondary_region = "us-west-2"

# Optional: set to true to enable Route 53 failover DNS.
# If false, the two S3 website endpoints work independently.
enable_route53_failover = false

# Required only when enable_route53_failover = true.
# hosted_zone_id = "Z1234567890ABCDEFGHIJ"
# domain_name    = "dr-demo.example.com"